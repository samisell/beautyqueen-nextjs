generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("user")
  avatar        String?
  isVerified    Boolean   @default(false)
  referredBy    String?
  referralCode  String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  votes          Vote[]
  purchasedVotes PurchasedVote[]
  payments       Payment[]
  reviewedPayments Payment[]     @relation("PaymentReviewer")
  sentReferrals  Referral[]      @relation("ReferrerReferrals")
  receivedReferrals Referral[]   @relation("ReferredReferrals")
  notifications  Notification[]
  voteLinks      VoteLink[]
  eliminatedContestants Contestant[]  @relation("Eliminator")
  contestantProfile    Contestant?     @relation("ContestantUser")
  bonusVotes     BonusVote[]  @relation("BonusVoteAdmin")
  emailVerification EmailVerification?
  ratedSubmissions TaskSubmission[]  @relation("TaskRater")

  @@index([email])
  @@index([referralCode])
  @@index([referredBy])
}

model Contestant {
  id               String    @id @default(cuid())
  name             String
  username         String?   @unique
  bio              String?
  imageUrl         String
  category         String
  categoryId       String?
  status           String    @default("active")
  totalVotes       Int       @default(0)
  stageId          String?
  userId           String?   @unique
  eliminatedAt     DateTime?
  eliminationReason String?
  eliminatedById   String?
  // Profile fields
  phone            String?
  address          String?
  country          String?
  state            String?
  bankName         String?
  bankAccountName  String?
  bankAccountNumber String?
  bankSortCode     String?
  socialLinks      String?   // JSON: { instagram, twitter, facebook, tiktok, youtube, website }
  gallery          String?   // JSON array: ["url1", "url2", ...]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  votes            Vote[]
  stage            TournamentStage?  @relation(fields: [stageId], references: [id])
  categoryRel      Category?         @relation(fields: [categoryId], references: [id])
  eliminatedBy     User?             @relation("Eliminator", fields: [eliminatedById], references: [id])
  user             User?             @relation("ContestantUser", fields: [userId], references: [id])
  bonusVotes       BonusVote[]
  publicPayments   Payment[]          @relation("PaymentContestant")
  taskSubmissions  TaskSubmission[]

  @@index([category])
  @@index([status])
  @@index([totalVotes(sort: Desc)])
  @@index([stageId])
  @@index([categoryId])
  @@index([username])
}

model Category {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  icon        String?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  contestants Contestant[]

  @@index([order])
}

model Vote {
  id              String         @id @default(cuid())
  contestantId    String
  userId          String?
  voteType        String         @default("free")
  ipAddress       String?
  purchasedVoteId String?
  createdAt       DateTime       @default(now())

  contestant    Contestant     @relation(fields: [contestantId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  purchasedVote PurchasedVote? @relation(fields: [purchasedVoteId], references: [id], onDelete: SetNull)

  @@index([contestantId])
  @@index([userId])
  @@index([ipAddress, createdAt])
  @@index([voteType])
  @@index([purchasedVoteId])
}

model VotePackage {
  id          String   @id @default(cuid())
  name        String
  votes       Int
  price       Float
  bonusVotes  Int      @default(0)
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases PurchasedVote[]
  payments  Payment[]

  @@index([isActive])
  @@index([order])
}

model PurchasedVote {
  id           String   @id @default(cuid())
  userId       String
  packageId    String
  paymentId    String?
  votesAmount  Int
  votesUsed    Int      @default(0)
  createdAt    DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  package VotePackage @relation(fields: [packageId], references: [id])
  votes  Vote[]

  @@index([userId])
  @@index([packageId])
  @@index([paymentId])
}

model Payment {
  id              String    @id @default(cuid())
  userId          String
  packageId       String
  amount          Float
  status          String    @default("pending")
  paymentMethod   String    @default("mock")
  transactionId   String?   @unique
  reference       String?
  gatewayRef      String?
  proofImageUrl   String?
  bankName        String?
  accountName     String?
  accountNumber   String?
  depositorName   String?
  adminNote       String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contestantId   String?
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  package VotePackage @relation(fields: [packageId], references: [id])
  reviewer User?      @relation("PaymentReviewer", fields: [reviewedBy], references: [id])
  contestant Contestant?  @relation("PaymentContestant", fields: [contestantId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paymentMethod])
  @@index([createdAt])
  @@index([contestantId])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages TournamentStage[]

  @@index([status])
}

model TournamentStage {
  id             String   @id @default(cuid())
  tournamentId   String
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  status         String   @default("upcoming")
  order          Int      @default(0)
  minVotes       Int      @default(0)
  maxContestants Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament  Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  contestants Contestant[]
  tasks       StageTask[]

  @@index([status])
  @@index([order])
  @@index([startDate])
  @@index([tournamentId])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model BonusVote {
  id           String   @id @default(cuid())
  contestantId String
  votesAdded    Int
  reason       String?
  addedById     String
  createdAt    DateTime @default(now())

  contestant Contestant @relation(fields: [contestantId], references: [id])
  addedBy     User       @relation("BonusVoteAdmin", fields: [addedById], references: [id])

  @@index([contestantId])
  @@index([addedById])
  @@index([createdAt])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  otp       String
  purpose   String   @default("verification")
 expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([otp])
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  to        String
  subject   String
  template  String
  status    String   @default("sent")
 error     String?
  data      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([template])
  @@index([status])
  @@index([createdAt])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  bonusVotes   Int      @default(0)
  createdAt    DateTime @default(now())

  referrer User @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredReferrals", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referredId])
  @@unique([referrerId, referredId])
}

model VoteLink {
  id           String   @id @default(cuid())
  userId       String
  contestantId String
  code         String   @unique
  clickCount   Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  title        String
  message      String
  type         String   @default("info")
  isRead       Boolean  @default(false)
  emailContent String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model StageTask {
  id          String   @id @default(cuid())
  stageId     String
  title       String
  description String?
  instructions String?
  dueDate     DateTime?
  status      String   @default("active")
  maxBonusVotes Int     @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stage        TournamentStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  submissions  TaskSubmission[]

  @@index([stageId])
  @@index([status])
  @@index([createdAt])
}

model TaskSubmission {
  id           String   @id @default(cuid())
  taskId       String
  contestantId String
  submissionUrl String
  caption      String?
  status       String   @default("pending")
  beautyRating Int?
  feedback     String?
  bonusVotesAwarded Int  @default(0)
  ratedById    String?
  ratedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task         StageTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  contestant   Contestant   @relation(fields: [contestantId], references: [id], onDelete: Cascade)
  ratedBy      User?        @relation("TaskRater", fields: [ratedById], references: [id])

  @@index([taskId])
  @@index([contestantId])
  @@index([status])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  category  String?
  message   String
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([isRead])
  @@index([createdAt])
}

model SupportTicket {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  userId      String?
  category    String
  priority    String   @default("medium")
  subject     String
  description String
  attachmentUrl String?
  status      String   @default("open")
  adminReply  String?
  repliedBy   String?
  repliedAt   DateTime?
  isReadByUser Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
  @@index([ticketId])
}
