generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ChatMessage {
  id                String   @id @default(cuid())
  sessionId         String
  userId            String?
  sender            String
  message           String
  senderName        String?
  senderEmail       String?
  isAdminRead       Boolean  @default(false)
  isUserRead        Boolean  @default(false)
  telegramMessageId Int?
  createdAt         DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([telegramMessageId])
  @@index([createdAt])
}
