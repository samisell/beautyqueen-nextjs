DATABASE_URL=file:/home/z/my-project/db/custom.db

# ── Telegram Bot Configuration ──
# Get your bot token from @BotFather on Telegram
# 1. Search for @BotFather in Telegram
# 2. Send /newbot and follow the prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The URL of your BeautyVote app (used by the bot for the "Open App" button)
TELEGRAM_WEB_APP_URL=https://beautyvote.app

# Public bot username (shown on the login page as "Continue with Telegram")
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=beautyvote_bot
