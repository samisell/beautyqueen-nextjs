DATABASE_URL=file:/home/z/my-project/db/custom.db

# ── Telegram Auth Bot Configuration ──
# Get your bot token from @BotFather on Telegram
# 1. Search for @BotFather in Telegram
# 2. Send /newbot and follow the prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The URL of your BeautyVote app (used by the bot for the "Open App" button)
TELEGRAM_WEB_APP_URL=https://beautyvote.app

# Public bot username (shown on the login page as "Continue with Telegram")
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=beautyvote_bot

# ── Telegram Support Chat Bot Configuration ──
# This is a SEPARATE bot from the auth bot — used for live chat support
# Create a new bot via @BotFather specifically for support
TELEGRAM_SUPPORT_BOT_TOKEN=your_support_bot_token_here

# Your Telegram user/chat ID (messages are forwarded to you)
# To find it: send /start to your support bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Look for "chat":{"id": 123456789} in the response
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id_here
