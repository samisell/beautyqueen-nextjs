# ═══════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ═══════════════════════════════════════════════════════
# AUTH & SECURITY
# ═══════════════════════════════════════════════════════
JWT_SECRET=beauty-vote-secret-key-change-in-production
REFRESH_SECRET=beauty-vote-refresh-secret-key
NODE_ENV=development

# ═══════════════════════════════════════════════════════
# SMTP / EMAIL CONFIGURATION
# ═══════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Beauty Vote <noreply@beautyvote.com>
EMAIL_FROM_NAME=Beauty Vote

# ═══════════════════════════════════════════════════════
# FLUTTERWAVE PAYMENT GATEWAY
# ═══════════════════════════════════════════════════════
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# ═══════════════════════════════════════════════════════
# PAYSTACK PAYMENT GATEWAY
# ═══════════════════════════════════════════════════════
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_BASE_URL=https://api.paystack.co

# ═══════════════════════════════════════════════════════
# APP SETTINGS
# ═══════════════════════════════════════════════════════
APP_URL=http://localhost:3000
APP_NAME=Beauty Vote
DEFAULT_VOTE_PRICE=200
DEFAULT_CURRENCY=NGN
